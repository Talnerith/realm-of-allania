# Firebase web app config (client-side; these NEXT_PUBLIC_ values are shipped to
# the browser by design and are protected by Firestore Security Rules + App Check).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# reCAPTCHA / App Check site key (public, client-side).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Optional. Ko-fi support handle. The navbar "Support" button renders only when
# this is set. Leave blank/unset to hide it.
NEXT_PUBLIC_KOFI_URL=
