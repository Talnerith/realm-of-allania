## Hook Ordering Rules

### 1. State Declarations First

```javascript
function MyComponent() {
  // ✅ All useState at the top
  const [count, setCount] = useState(0);
  const [data, setData] = useState([]);
  const [loading, setLoading] = useState(false);
  
  // Then other hooks...
}
```

### 2. useCallback/useMemo Before useEffect

```javascript
function MyComponent() {
  const [data, setData] = useState([]);
  
  // ✅ Define callbacks BEFORE effects that use them
  const handleClick = useCallback(() => {
    console.log(data);
  }, [data]);
  
  const processedData = useMemo(() => {
    return data.map(item => item * 2);
  }, [data]);
  
  // ✅ Now use them in effects
  useEffect(() => {
    handleClick();
  }, [handleClick]);
  
  return <div>{processedData}</div>;
}
```

### 3. Refs After Callbacks

```javascript
function MyComponent() {
  const [data, setData] = useState([]);
  
  const handleScroll = useCallback(() => {
    scrollRef.current?.scrollIntoView();
  }, []);
  
  // ✅ Refs used in callbacks should be declared after
  const scrollRef = useRef(null);
  
  return <div ref={scrollRef}>...</div>;
}
```

